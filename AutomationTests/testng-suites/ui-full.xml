<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CineReserve UI Full Test Suite" verbose="1" parallel="none" thread-count="1">

    <parameter name="env" value="local"/>

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <test name="Login UI Tests">
        <classes>
            <class name="com.cinereserve.ui.tests.LoginUITest"/>
        </classes>
    </test>

    <test name="Movies UI Tests">
        <classes>
            <class name="com.cinereserve.ui.tests.MoviesUITest"/>
        </classes>
    </test>

    <test name="Admin UI Tests">
        <classes>
            <class name="com.cinereserve.ui.tests.AdminUITest"/>
        </classes>
    </test>

</suite>
